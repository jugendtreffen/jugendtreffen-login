generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_TRANSACTION_POOLER_URL")
  directUrl = env("SUPABASE_SESSION_POOLER_URL")
}

model RegisteredParticipant {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String
  familyName            String
  birthdate             DateTime @db.Date
  gender                String
  phoneNumber           String
  phoneCaretakerContact String?
  foundUsBy             String?
  isParent              Boolean  @default(false)
  country               String
  city                  String
  postalCode            String
  address               String
  travelMethod          String?
  accommodation         String
  startDate             DateTime @db.Date
  endDate               DateTime @db.Date
  foodChoice            String
  acceptPhotos          Boolean
  acceptCoC             Boolean
  eventId               BigInt   @db.BigInt
  event                 Event    @relation(fields: [eventId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  participationRole     String?
  createdAt             DateTime @default(now())

  @@map("registeredParticipants")
}

model Event {
  id           BigInt                  @id @default(autoincrement()) @db.BigInt
  name         String                  @unique
  desc         String?
  startDate    DateTime                @db.Date
  endDate      DateTime                @db.Date
  participants RegisteredParticipant[]
  presences    Presence[]
  createdAt    DateTime                @default(now())

  @@map("events")
}

model Presence {
  id      BigInt   @id @default(autoincrement()) @db.BigInt
  date    DateTime @db.Date
  status  String
  userId  String   @db.Uuid
  eventId BigInt   @db.BigInt
  event   Event    @relation(fields: [eventId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@map("presences")
}
