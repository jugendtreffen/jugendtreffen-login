{
  "private": true,
  "workspaces": {
    "packages": [
      "api",
      "web"
    ]
  },
  "scripts": {
    "dev": "redwood dev",
    "build:dev": "redwood build",
    "build:prod": "dotenv -f .env.production run redwood build",
    "start": "redwood serve",
    "migrate:dev": "redwood prisma migrate dev",
    "migrate:prod": "dotenv -f .env.production run redwood prisma migrate deploy",
    "format-db": "redwood prisma format && redwood prisma validate --schema api/db/schema.prisma",
    "push-db": "redwood prisma db push",
    "seed": "redwood prisma db seed",
    "generate types": "redwood generate types",
    "test": "redwood test --watchAll"
  },
  "devDependencies": {
    "@redwoodjs/auth-supabase-setup": "8.8.1",
    "@redwoodjs/core": "8.8.1",
    "@redwoodjs/project-config": "8.8.1",
    "@redwoodjs/testing": "8.8.1"
  },
  "eslintConfig": {
    "extends": "@redwoodjs/eslint-config",
    "root": true
  },
  "engines": {
    "node": "=22.x"
  },
  "prisma": {
    "seed": "yarn rw exec seed"
  },
  "packageManager": "yarn@4.4.0"
}
